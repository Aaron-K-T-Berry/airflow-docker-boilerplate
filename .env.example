# Example env file for docker compose.
# Copy to .env and adjust as needed:
#   cp .env.example .env
#
# On Linux, AIRFLOW_UID should match your host user id so mounted
# files are not owned by root.

AIRFLOW_UID=50000
# Optional: set a Fernet key for encrypting connections/variables
# FERNET_KEY=
# Optional: override JWT secret used by the API server
# AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret
